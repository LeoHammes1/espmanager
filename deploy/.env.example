# Copy to deploy/.env and set strong values. docker compose reads it automatically.

# Shared secret the builder uses to authenticate to the core (Bearer token).
ESPM_WORKER_TOKEN=change-me-worker

# Shared secret the core uses to authenticate to the signer (Bearer token).
ESPM_SIGNER_TOKEN=change-me-signer

# Management UI credentials. Required by the compose deployment.
ESPM_ADMIN_USER=admin
ESPM_ADMIN_PASSWORD=change-me-admin

# Device-reachable base URL of the core, used to build OTA firmware URLs.
# Set it to the host address devices can reach (e.g. http://192.168.1.10:8080).
# Leave empty to disable OTA rollouts.
ESPM_PUBLIC_URL=

# IMPORTANT: the signer-data volume holds the ed25519 signing key — the root of
# trust every device verifies OTA firmware against. If it is lost (e.g.
# `docker compose down -v`, volume pruning, or rebuilding the LXC) the signer
# regenerates a NEW key and every already-provisioned device rejects all future
# OTA. Back it up after first boot and restore it before re-deploying:
#   docker compose cp signer:/app/data/signing.key ./signing.key.bak
