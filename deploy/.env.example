# Copy to deploy/.env and set strong values. docker compose reads it automatically.

# Shared secret the builder uses to authenticate to the core (Bearer token).
ESPM_WORKER_TOKEN=change-me-worker

# Shared secret the core uses to authenticate to the signer (Bearer token).
ESPM_SIGNER_TOKEN=change-me-signer

# Management UI credentials. Required by the compose deployment.
ESPM_ADMIN_USER=admin
ESPM_ADMIN_PASSWORD=change-me-admin

# Device-reachable base URL used to build OTA firmware URLs. Devices fetch
# firmware over plain HTTP (they cannot do TLS; integrity is from the ed25519
# signature), so this MUST be http:// on port 80 — Caddy's :80 listener proxies
# the device paths (/v1, /firmware) to the core in plain HTTP and redirects
# everything else to HTTPS. e.g. http://192.168.1.10  (or http://esp.lan).
# https here is rejected at startup. Leave empty to disable OTA rollouts.
ESPM_PUBLIC_URL=

# Browser-facing origin (the https Caddy address). Drives Secure session cookies.
# e.g. https://esp.example.com or https://192.168.1.10
ESPM_BROWSER_URL=

# TLS: Caddy (deploy/Caddyfile) terminates HTTPS in front of the core so the
# browser is a secure context — required by the USB "Add device" wizard (Web
# Serial needs Chromium + a TRUSTED https origin). By default Caddy mints
# self-signed certs from its internal CA for any host/IP; trust that root CA on
# the workstation once (caddy-data volume: pki/authorities/local/root.crt) or
# Chrome hides the wizard. For a real public domain + Let's Encrypt, edit
# deploy/Caddyfile (see the comments there).

# IMPORTANT: the signer-data volume holds the ed25519 signing key — the root of
# trust every device verifies OTA firmware against. If it is lost (e.g.
# `docker compose down -v`, volume pruning, or rebuilding the LXC) the signer
# regenerates a NEW key and every already-provisioned device rejects all future
# OTA. Back it up after first boot and restore it before re-deploying:
#   docker compose cp signer:/app/data/signing.key ./signing.key.bak
